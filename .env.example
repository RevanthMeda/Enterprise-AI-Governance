# Core runtime
# Checked-in defaults only. Put real local secrets in .env.local.
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enterprise_ai_governance
SESSION_SECRET=<set-a-long-random-session-secret>
# Production should use a dedicated reset secret and vault secret as well.
CSRF_ENFORCED=true
TRUST_PROXY=false
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

# Vault / provider secrets
CONTROL_TOWER_VAULT_SECRET=<set-a-long-random-vault-secret>
OPENAI_API_KEY=<set-your-openai-api-key>
OPENROUTER_API_KEY=<set-your-openrouter-api-key>
OPENROUTER_MODEL=qwen/qwen3-coder:free

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=<set-your-supabase-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<set-your-supabase-service-role-key>

# Public client configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<set-your-supabase-publishable-key>

# Email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@example.com
SMTP_PASSWORD=<set-your-smtp-password>
SMTP_FROM=notifications@example.com
PASSWORD_RESET_SECRET=<set-a-dedicated-password-reset-secret>
PASSWORD_RESET_TTL_MINUTES=30
# Optional webhook alternative for password reset delivery
# PASSWORD_RESET_WEBHOOK_URL=https://example.com/password-reset-webhook

# Public app URLs
PUBLIC_APP_URL=http://localhost:5000
CORS_ALLOWED_ORIGINS=http://localhost:5000
# Cross-origin production frontends normally also need:
# SESSION_COOKIE_SAME_SITE=none
# SESSION_COOKIE_SECURE=true
# TRUST_PROXY=true

# Baseline test-user seeding
SEED_TEST_USERS=false
TEST_USER_PASSWORD=<set-a-local-test-password>
RESET_TEST_USER_PASSWORDS=false
