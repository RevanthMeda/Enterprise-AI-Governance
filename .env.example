# Core runtime
# Checked-in defaults only. Put real local secrets in .env.local.
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enterprise_ai_governance
SESSION_SECRET=<set-a-long-random-session-secret>
# Optional emergency local-login override for SSO-enforced organizations.
# When configured in production, use a unique random value of at least 32 characters.
# BREAK_GLASS_TOKEN=<set-a-long-random-break-glass-token>
# Production should use a dedicated reset secret and vault secret as well.
CSRF_ENFORCED=true
TRUST_PROXY=false
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_PARTITIONED=false
# Cross-site partitioned deployments should use a versioned name such as:
# SESSION_COOKIE_NAME=__Host-aict.sid.v2

# Vault / provider secrets
CONTROL_TOWER_VAULT_SECRET=<set-a-long-random-vault-secret>
# Optional dedicated HMAC key for privacy-safe shared rate-limit identifiers.
# When omitted, CONTROL_TOWER_VAULT_SECRET is used. Keep this stable across all
# backend instances that share a database.
# RATE_LIMIT_HMAC_SECRET=<set-a-long-random-rate-limit-secret>
# RATE_LIMIT_NAMESPACE=production
OPENAI_API_KEY=<set-your-openai-api-key>
OPENROUTER_API_KEY=<set-your-openrouter-api-key>
OPENROUTER_MODEL=qwen/qwen3-coder:free
# Optional LLM governance critic for runtime review.
AICT_GOVERNANCE_CRITIC_ENABLED=false
AICT_GOVERNANCE_CRITIC_MODEL=gpt-4.1-mini
# Leave blank to reuse OPENAI_API_KEY when the critic is enabled.
# AICT_GOVERNANCE_CRITIC_API_KEY=<set-your-governance-critic-key>
# AICT_GOVERNANCE_CRITIC_BASE_URL=https://api.openai.com/v1/chat/completions
# Optional stricter preview policy that runs alongside the live decision without changing enforcement.
AICT_GOVERNANCE_SHADOW_MODE_ENABLED=false
AICT_GOVERNANCE_SHADOW_MODE_LABEL=stricter-preview

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=<set-your-supabase-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<set-your-supabase-service-role-key>

# Public client configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<set-your-supabase-publishable-key>

# Email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@example.com
SMTP_PASSWORD=<set-your-smtp-password>
SMTP_FROM=notifications@example.com
PASSWORD_RESET_SECRET=<set-a-dedicated-password-reset-secret>
PASSWORD_RESET_TTL_MINUTES=30
# Optional webhook alternative for password reset delivery
# PASSWORD_RESET_WEBHOOK_URL=https://example.com/password-reset-webhook
# Optional governance event stream destination
# GOVERNANCE_EVENT_WEBHOOK_URL=https://example.com/governance-events
# GOVERNANCE_EVENT_WEBHOOK_TOKEN=<optional-bearer-token>

# Public app URLs
PUBLIC_APP_URL=http://localhost:5000
API_PUBLIC_URL=http://localhost:5000
CORS_ALLOWED_ORIGINS=http://localhost:5000
# Cross-origin production frontends normally also need:
# SESSION_COOKIE_SAME_SITE=none
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_PARTITIONED=true
# TRUST_PROXY=true

# Evidence files use the local filesystem. In production, mount a persistent
# volume and point this at a directory inside that mount (Render example below).
# UPLOAD_ROOT=/var/data/uploads
EVIDENCE_STORAGE_DURABLE=false
# Enable only after the persistent mount and UPLOAD_ROOT have been verified.
REQUIRE_DURABLE_EVIDENCE_STORAGE=false
# Optional evidence quotas. Defaults shown: 10 GiB / 50,000 files per org,
# and 1 GiB / 500 files per uploader in a rolling 24-hour window.
# EVIDENCE_ORG_MAX_BYTES=10737418240
# EVIDENCE_ORG_MAX_FILES=50000
# EVIDENCE_USER_DAILY_MAX_BYTES=1073741824
# EVIDENCE_USER_DAILY_MAX_FILES=500
# Render supplies RENDER_GIT_COMMIT automatically for Git-backed services.
# Other hosts can supply RELEASE_COMMIT_SHA so release gates can identify the
# exact backend revision.

# Development-only behavior. The application hard-disables these in
# production; keep them false in every deployed environment as well.
AUTO_SEED_ON_STARTUP=false
SEED_TEST_USERS=false
TEST_USER_PASSWORD=<set-a-local-test-password>
RESET_TEST_USER_PASSWORDS=false
ENABLE_TEST_AUTH_ROUTES=false
EXPOSE_INVITE_TOKENS=false
ALLOW_SELF_SIGNUP=false
# Legacy unsigned SAML fixtures are accepted only when NODE_ENV=test and this is true.
ALLOW_INSECURE_SAML_TEST_FIXTURES=false
# Test-only escape hatch for local HTTP/private-address OIDC fixtures. Ignored
# unless NODE_ENV=test; never enable in a deployed environment.
ALLOW_INSECURE_OIDC_TEST_PROVIDER=false
# Optional comma-separated HTTPS origins for providers whose authorization,
# token, or JWKS endpoint intentionally differs from the issuer origin.
# OIDC_TRUSTED_ENDPOINT_ORIGINS=https://login.example.com
