# Northstar linked-runtime configuration
# Copy only the values you need into ignored examples/.env.local.

# Deployed AI CONTROL GRID used by local Northstar in demo:remote mode.
AICT_BASE_URL=https://enterprise-ai-governance.onrender.com
AICT_CONSOLE_URL=https://ai-control-tower-d9854.web.app
AICT_TELEMETRY_KEY=<set-your-rotated-telemetry-key>
# Leave blank only when Telemetry Adapter has Northstar as its default system.
AICT_SYSTEM_ID=
AICT_TIMEOUT_MS=30000
AICT_DEMO_TURN_TIMEOUT_MS=60000

# Server-side model gateway
AICT_MODEL_ENDPOINT=https://atira-production-b70d.up.railway.app/api/gateway/chat
AICT_MODEL_API_KEY=<set-your-rotated-gateway-key>
AICT_MODEL_REQUEST_FORMAT=dynamic
AICT_GATEWAY=atira-dynamic-gateway
AICT_PROVIDER=atira-cohere
AICT_MODEL_NAME=dynamic
AICT_DEMO_MODEL_TIMEOUT_MS=12000
AICT_DEMO_MAX_LIVE_MODEL_CALLS=50
AICT_DEMO_MAX_CONCURRENT_MODEL_CALLS=2

# Local demo ports
LINKED_RUNTIME_DEMO_PORT=18080
LINKED_RUNTIME_DEMO_BIND_HOST=127.0.0.1
