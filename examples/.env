# Checked-in defaults only. Put real local secrets in examples/.env.local.
AICT_BASE_URL=http://localhost:5000
AICT_TELEMETRY_KEY=<set-your-telemetry-key>
AICT_SYSTEM_ID=<set-your-system-id>
AICT_GATEWAY=linked-demo-gateway
AICT_PROVIDER=openai
AICT_MODEL_NAME=gpt-4.1-mini
LINKED_RUNTIME_DEMO_PORT=18080
OPENAI_API_KEY=<set-your-openai-api-key>
